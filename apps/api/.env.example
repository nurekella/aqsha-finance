NODE_ENV=development
API_PORT=3000

# Database (matches infra/docker-compose.dev.yml)
DATABASE_URL=postgresql://aqsha:aqsha@localhost:5432/aqsha?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# CORS
WEB_ORIGIN=http://localhost:5173
