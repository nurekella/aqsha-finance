# Скопируйте в /opt/aqsha-finance/.env и подставьте реальные значения

# Домен (должен совпадать с Proxy Host в NPM)
DOMAIN=aqsha.nurekella.tech

# Тег образов: latest или конкретный SHA из ghcr.io
IMAGE_TAG=latest

# PostgreSQL
POSTGRES_USER=aqsha
POSTGRES_PASSWORD=ОБЯЗАТЕЛЬНО_ИЗМЕНИТЬ
POSTGRES_DB=aqsha

# JWT — сгенерируйте: openssl rand -hex 32
JWT_ACCESS_SECRET=ОБЯЗАТЕЛЬНО_ИЗМЕНИТЬ
JWT_REFRESH_SECRET=ОБЯЗАТЕЛЬНО_ИЗМЕНИТЬ
